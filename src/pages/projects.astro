---
import Layout from '../layouts/Layout.astro';
const myProjects = [
  { name: 'Weed Detection', desc: 'YOLO-based weed detection system', tags: ['YOLO', 'RT-DETR'], imgsrc:'/assets/Ranch.JPG',link:'/projects/weeddetection'},
  { name: 'Classification Map in Pasture', desc: 'Drone-based data visualization', tags: ['Drone Mapping', 'Vegetative Indices','SVM'], imgsrc:'/assets/ortho.png',link:'/projects/classification'},
  { name: 'Flood Analysis', desc: 'Analysis of flood in Kerr County', tags: ['Sentinel-2', 'Remote Sensing','Land Cover'] , imgsrc:'/assets/LandCover_Kerr.jpg', link:'https://rashmidangol.github.io/flood_analysis_Kerr_county/'},
];
---

<Layout title="Projects | Rashmi Dangol">
  <main class="max-w-6xl mx-auto py-20 px-6">
    <header class="text-center mb-16 reveal">
      <h1 class="text-5xl font-black mb-4">My <span class="text-primary">Projects</span></h1>
      <p class="text-xl opacity-70">A collection of things I've built and experimented with.</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      {myProjects.map((p, i) => (
        <div class="group card lg:card-side bg-base-200 shadow-xl reveal overflow-hidden" style={`transition-delay: ${i * 100}ms;`}>
          <figure class="lg:w-1/3 overflow-hidden">
            <img src={p.imgsrc} alt="Project" class="group-hover:scale-110 transition-transform duration-500 h-full object-cover"/>
          </figure>
          <div class="card-body lg:w-2/3">
            <h2 class="card-title text-2xl group-hover:text-primary transition-colors">{p.name}</h2>
            <p>{p.desc}</p>
            <div class="card-actions justify-start mt-4">
              {p.tags.map((tag, tagIndex) => {
                const badgeClasses = [
                  'badge badge-primary badge-outline',
                  'badge badge-secondary badge-outline',
                  'badge badge-accent badge-outline',
                ];
                return <div class={badgeClasses[tagIndex % badgeClasses.length]}>{tag}</div>;
              })}
            </div>
            <div class="card-actions justify-end">
              {p.link && <a href={p.link} class="btn btn-primary btn-sm ml-2" target="_blank" rel="noopener">View Study</a>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>