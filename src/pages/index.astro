---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
// Importing the image properly for Astro's optimization
import rashmiImage from '../assets/rashmi.jpg'; 
---

<Layout title="Rashmi Dangol | Home">
  <main class="overflow-x-hidden">
    
    <section class="hero min-h-[85vh] bg-base-200 px-4 md:px-10">
      <div class="hero-content flex-col lg:flex-row gap-10 lg:gap-20">
        
        <div class="flex-shrink-0 animate-slide-in-left">
          <div class="avatar shadow-2xl">
            <div class="w-48 h-48 md:w-64 md:h-64 rounded-2xl ring ring-primary ring-offset-base-100 ring-offset-4 hover:rotate-2 transition-transform duration-500">
              <Image 
                src={rashmiImage} 
                alt="Rashmi Dangol" 
                class="object-cover"
                loading="eager"
              />
            </div>
          </div>
        </div>

        <div class="max-w-2xl text-center lg:text-left animate-slide-in-right">
          <h1 class="text-5xl md:text-7xl font-black mb-2 leading-tight">
            Hello, I'm <span class="text-primary">Rashmi Dangol</span>
          </h1>
          <h2 class="text-2xl md:text-3xl font-bold text-secondary mb-6 italic">
            Digital Agronomist | Geospatial Analysis Enthusiast
          </h2>
          <p class="text-lg md:text-xl opacity-0 animate-fade-in-delayed leading-relaxed">
            I specialize in precision agriculture, leveraging drone-based data workflows to solve real-world challenges in rangeland systems through
            <span class="text-accent font-semibold">data-driven solutions</span>. 
           
          </p>
          <div class="opacity-0 animate-pop-in mt-8 flex flex-wrap gap-4 justify-center lg:justify-start">
            <a href="/projects" class="btn btn-primary btn-lg shadow-xl hover:scale-105 transition-all">
              Explore Projects
            </a>
            <a href="assets/DangolRashmi-Resume.pdf" target="_blank" rel="noopener" class="btn btn-outline btn-lg hover:bg-base-300 transition-all">
              Download Resume
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="projects" class="py-24 max-w-6xl mx-auto px-6">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 reveal">
        <div>
          <h2 class="text-4xl font-bold mb-2">Featured Work</h2>
          <div class="h-1 w-20 bg-primary"></div>
        </div>
        <a href="/projects" class="link link-primary hidden md:block mt-4 text-xl">View all projects →</a>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {[
          { name: 'Weed Detection', img: '/assets/Ranch.JPG',desc: 'YOLO-based weed detection system using deep learning for accurate species identification',  tags: ['YOLO', 'RT-DETR'] }, 
          { name: 'Classification in Pasture', img: '/assets/ortho.png',desc: 'Drone-based mapping and vegetation classification using SVM and spectral indices',  tags: ['Drone Mapping', 'Vegetative Indices','SVM'] }, 
          { name: 'Flood Analysis', img: '/assets/LandCover_Kerr.jpg', desc: 'Remote sensing analysis of flood dynamics using Sentinel-2 and soil moisture data',  tags: ['Sentinel-2', 'Soil_data','Land Cover'] } 
        ].map((project, index) => (
          <div 
            class="group card bg-base-100 shadow-xl border border-base-300 reveal opacity-0 translate-y-24 scale-95 transition-all duration-1000 ease-out hover:shadow-primary/20"
            style={`transition-delay: ${index * 150}ms;`}
          >
            <figure class="relative overflow-hidden aspect-video">
              <img 
                src={project.img} 
                alt={project.name} 
                class="transition-transform duration-700 group-hover:scale-110 group-hover:rotate-1"
              />
              <div class="absolute inset-0 bg-primary/20 opacity-0 group-hover:opacity-100 transition-all duration-500"></div>
            </figure>
            
            <div class="card-body">
              <h2 class="card-title text-2xl group-hover:text-primary transition-colors">{project.name}</h2>
              <p class="opacity-70">{project.desc}</p>
              <div class="card-actions justify-start mt-4">
                {project.tags.map((tag, tagIndex) => {
                  const badgeClasses = [
                    'badge badge-primary badge-outline',
                    'badge badge-secondary badge-outline',
                    'badge badge-accent badge-outline',
                  ];
                  return <div class={badgeClasses[tagIndex % badgeClasses.length]}>{tag}</div>;
                })}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="py-20 bg-base-200">
       <div class="max-w-4xl mx-auto text-center px-6 reveal">
          <h2 class="text-3xl font-bold mb-6">Want to know more?</h2>
          <p class="text-lg mb-8 opacity-80">I'm open to new opportunities and collaborations in remote sensing and geospatial technology.</p>
          <a href="/about" class="btn btn-secondary btn-outline px-10">Read My Story</a>
       </div>
    </section>
  </main>
</Layout>

<style>
  @keyframes slideInRight {
    from { opacity: 0; transform: translateX(100px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes slideInLeft {
    from { opacity: 0; transform: translateX(-100px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes popIn {
    0% { opacity: 0; transform: scale(0.5); }
    70% { transform: scale(1.05); }
    100% { opacity: 1; transform: scale(1); }
  }

  .animate-slide-in-right { animation: slideInRight 1s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .animate-slide-in-left { animation: slideInLeft 1s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  .animate-fade-in-delayed { animation: fadeIn 1s ease-out 0.6s forwards; }
  .animate-pop-in { animation: popIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.8s forwards; }
</style>